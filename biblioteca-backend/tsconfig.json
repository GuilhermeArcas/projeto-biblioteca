{
  "compilerOptions": {
    "target": "ES2022",                          
    "module": "commonjs",                        
    "lib": ["ES2022"],                           
    "allowJs": true,                             
    "outDir": "./dist",                          
    "rootDir": "./src",                          
    "strict": true,                              
    "noImplicitAny": true,                       
    "esModuleInterop": true,                     
    "experimentalDecorators": true,              
    "emitDecoratorMetadata": true,               
    "skipLibCheck": true,                        
    "forceConsistentCasingInFileNames": true     
  },
  "include": ["src/**/*", "tests/**/*"]
}